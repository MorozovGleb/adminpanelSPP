<Window x:Class="SPP.Client.Views.Instructor.Moduls.IntroductoryMeetingWithTheInstructor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вкусно – и точка | Обучение"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="False"
        Background="#F5F5F5">
        <Window.Resources>
            <SolidColorBrush x:Key="PrimaryRed" Color="#D52B1E"/>
            <SolidColorBrush x:Key="DarkRed" Color="#A61C12"/>
            <SolidColorBrush x:Key="Gold" Color="#FFC107"/>
            <SolidColorBrush x:Key="LightGray" Color="#F9F9F9"/>
            <SolidColorBrush x:Key="MediumGray" Color="#EEEEEE"/>
            <SolidColorBrush x:Key="TextDark" Color="#2C2C2C"/>
            <SolidColorBrush x:Key="TextMedium" Color="#5A5A5A"/>
            <SolidColorBrush x:Key="WarningYellow" Color="#FFF3E0"/>
            <SolidColorBrush x:Key="InfoBlue" Color="#F0F8FF"/>
            <SolidColorBrush x:Key="SuccessGreen" Color="#E8F5E9"/>

            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource DarkRed}"/>
                <Setter Property="Margin" Value="0,15,0,8"/>
            </Style>

            <Style x:Key="SubTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
                <Setter Property="Margin" Value="0,10,0,5"/>
            </Style>

            <Style x:Key="BulletTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                <Setter Property="Margin" Value="0,4,0,4"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="NumberedStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                <Setter Property="Margin" Value="0,3,0,3"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="0,0,0,15"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="NavButtonStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="30"/>
                <Setter Property="Padding" Value="20,12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,10,0,5"/>
            </Style>
        </Window.Resources>

        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40,30,40,40">

                <!-- ==================== СТРАНИЦА 1 ==================== -->
                <StackPanel x:Name="Page1">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Ценности и гостеприимство" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 9" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock FontSize="16" Foreground="{StaticResource TextDark}" TextWrapping="Wrap" Margin="0,0,0,15">
                    Дорогой друг, добро пожаловать в компанию <Run FontWeight="Bold" Foreground="{StaticResource PrimaryRed}">«Вкусно – и точка»</Run>!
                    </TextBlock>
                    <TextBlock FontSize="15" Foreground="{StaticResource TextDark}" TextWrapping="Wrap" Margin="0,0,0,20">
                    Сегодня твой первый день обучения и начнем с «Вводного ознакомления с инструктором». Рассмотрим темы:
                    </TextBlock>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="15,10" BorderBrush="{StaticResource PrimaryRed}" BorderThickness="0,0,0,3">
                            <TextBlock Text="Наши Ценности и гостеприимство" TextAlignment="Center" TextWrapping="Wrap" FontWeight="SemiBold"/>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="15,10" BorderBrush="{StaticResource PrimaryRed}" BorderThickness="0,0,0,3">
                            <TextBlock Text="Безопасность предприятия и техника безопасности" TextAlignment="Center" TextWrapping="Wrap" FontWeight="SemiBold"/>
                        </Border>
                        <Border Grid.Column="4" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="15,10" BorderBrush="{StaticResource PrimaryRed}" BorderThickness="0,0,0,3">
                            <TextBlock Text="Качество и безопасность пищи" TextAlignment="Center" TextWrapping="Wrap" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="Наши 5 ключевых Ценностей выстроены вокруг гостей, команд, сообществ, партнеров и достижения бизнес-результатов. Давайте посмотрим, что мы можем делать, чтобы демонстрировать каждую из них." FontSize="14" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SubTitleStyle}">🧑‍🍳 Гости – наш приоритет</TextBlock>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы знаем и соблюдаем стандарты ККЧ и помогаем коллегам"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы оперативно реагируем на просьбы и обратную связь"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы своевременно знакомимся с новой информацией"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы гостеприимны, вежливы, соблюдаем стандарты внешнего вида"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SubTitleStyle}">🤝 Мы – команда, ценим вклад каждого</TextBlock>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Относимся с уважением, помогаем, ценим вклад каждого"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Используем идеи коллег, делимся своими"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Обмениваемся обратной связью"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Помогаем новым сотрудникам"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Оцениваем сильные и слабые стороны"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Отвечаем за свои действия"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SubTitleStyle}">⚖️ Честность и порядочность</TextBlock>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Честны с коллегами, руководителями, партнерами"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Выбираем партнеров, разделяющих наши Ценности"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Не распространяем конфиденциальную информацию"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Честно говорим о результатах, сообщаем об ошибках"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Выполняем обещания"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SubTitleStyle}">🌿 Забота о тех, кто рядом</TextBlock>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Учитываем влияние решений на окружающих"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Используем возможность поддержать тех, кто нуждается"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Участвуем в волонтерских программах"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Проявляем заботу о гостях и коллегах"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SubTitleStyle}">📈 Предпринимательский подход и ответственность</TextBlock>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Неукоснительно выполняем стандарты"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Бережно относимся к продукции и оборудованию"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource WarningYellow}" CornerRadius="12" Padding="20" Margin="0,10,0,20" BorderBrush="{StaticResource Gold}" BorderThickness="1">
                        <TextBlock Text="📘 Примечание для инструктора: Пройдите с работником в зал и посмотрите, как взаимодействуют сотрудники с гостями. Изучение раздела «Гостеприимство» проводится в зале." TextWrapping="Wrap"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Перейдем к следующему этапу →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TextBlock Text="Передайте планшет работнику." FontSize="14" Foreground="{StaticResource TextMedium}" TextAlignment="Center" Margin="0,15,0,0" FontStyle="Italic"/>
                </StackPanel>

                <!-- ==================== СТРАНИЦА 2 ==================== -->
                <StackPanel x:Name="Page2" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Ценности и гостеприимство" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="2 из 9" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Что такое гостеприимство" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock FontSize="15" TextWrapping="Wrap" Margin="0,0,0,15">Наша самая первая Ценность — <Run FontWeight="Bold" Foreground="{StaticResource PrimaryRed}">«Гости – наш приоритет»</Run>. Мы хотим, чтобы гости получали только наилучшие впечатления от посещения ПБО, а сотрудники были гостеприимными.</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" FontSize="16">🤝 Что такое гостеприимство?</TextBlock>
                            <TextBlock Text="Гостеприимство — это радушные приветствия, теплые прощания, улыбки и визуальный контакт." Margin="0,10,0,10" TextWrapping="Wrap"/>
                            <TextBlock Text="Наши принципы гостеприимства — простые, но важные мелочи:" FontWeight="SemiBold"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ дружелюбное приветствие или предложение помочь донести поднос"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ короткая беседа или помощь в оформлении заказа через Киоск самообслуживания"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Style="{StaticResource SectionTitleStyle}">Ожидания гостей</TextBlock>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="✅ Правильно и Точно" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="⚡ Быстро" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                        <Border Grid.Column="4" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="😊 Дружелюбно" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Style="{StaticResource SectionTitleStyle}">🔄 Цикл обслуживания гостей</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="1. Взаимодействие на входе: приветствуйте, улыбайтесь"/>
                            <TextBlock Text="2. Заказ и оплата: рассказывайте об опциях сервиса, помогайте с Киосками"/>
                            <TextBlock Text="3. Получение заказа: правильно работайте с мониторами, аккуратно собирайте"/>
                            <TextBlock Text="4. В зале: помогайте гостю, поддерживайте чистоту"/>
                            <TextBlock Text="5. Взаимодействие на выходе: искренне прощайтесь, приглашайте снова"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Решающие моменты – это то, что формирует впечатление гостя о бренде." FontStyle="Italic" Margin="0,0,0,20"/>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ==================== СТРАНИЦА 3 ==================== -->
                <StackPanel x:Name="Page3" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Ценности и гостеприимство" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="3 из 9" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Все начинается с вас" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Впечатление гостя от посещения предприятия начинается с вас. Оно зависит от того, о чем вы думаете, как себя чувствуете и как выглядите каждый день." TextWrapping="Wrap" Margin="0,0,0,15"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource MediumGray}" CornerRadius="8" Padding="8">
                            <TextBlock Text="Произвести первое впечатление" TextAlignment="Center" TextWrapping="Wrap"/>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource MediumGray}" CornerRadius="8" Padding="8">
                            <TextBlock Text="Вежливость" TextAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="4" Background="{StaticResource MediumGray}" CornerRadius="8" Padding="8">
                            <TextBlock Text="Образ мышления" TextAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="6" Background="{StaticResource MediumGray}" CornerRadius="8" Padding="8">
                            <TextBlock Text="Теплота и приветливость" TextAlignment="Center" TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                    <TextBlock Style="{StaticResource SectionTitleStyle}">Прекрасные первые впечатления</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">🔍 Из чего складывается первое впечатление?</TextBlock>
                            <TextBlock Text="👕 Внешний вид: чистота и аккуратность униформы"/>
                            <TextBlock Text="💬 Язык тела: невербальные сигналы"/>
                            <TextBlock Text="🏢 Окружающая обстановка: чистота вокруг"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource WarningYellow}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                        <TextBlock Text="💬 Обсуждение с инструктором: какое у вас первое впечатление? Кто кажется более дружелюбным? Как улыбка влияет на впечатление?" TextWrapping="Wrap"/>
                    </Border>
                    <TextBlock Style="{StaticResource SectionTitleStyle}">🎭 Упражнение «Улыбка с теплом и без тепла»</TextBlock>
                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <StackPanel>
                            <TextBlock Text="1️⃣ улыбнитесь только лицом (без радости внутри)"/>
                            <TextBlock Text="2️⃣ представьте солнышко внутри, улыбнитесь от сердца"/>
                            <TextBlock Text="Поменяйтесь ролями с инструктором." FontStyle="Italic" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Style="{StaticResource SectionTitleStyle}">❓ Вопросы после упражнения</TextBlock>
                    <TextBlock Text="• Какую разницу в улыбке заметили?" Margin="0,0,0,5"/>
                    <TextBlock Text="• Что почувствовали, когда вам улыбались по-разному?" Margin="0,0,0,10"/>
                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource SuccessGreen}">
                        <TextBlock Text="📌 Вывод: люди должны чувствовать наше «солнышко внутри». Даже полуулыбки достаточно, если внутри — открытость и приветливость." TextWrapping="Wrap"/>
                    </Border>
                    <TextBlock Text="✨ Приветливость передается:" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock Text="• Искренней улыбкой и доброжелательным выражением лица"/>
                    <TextBlock Text="• Солнышком в глазах"/>
                    <TextBlock Text="• Доброжелательными интонациями"/>
                    <TextBlock Text="⚠️ Гости чувствуют неискренность. Следите, чтобы слова и мимика не расходились." Margin="0,15,0,0" Foreground="#C62828" FontWeight="SemiBold"/>
                    <TextBlock Text="Теперь давайте разберемся, почему для гостей важна вежливость." Margin="0,20,0,10" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryRed}"/>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ==================== СТРАНИЦА 4 ==================== -->
                <StackPanel x:Name="Page4" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Ценности и гостеприимство" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="4 из 9" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Дружелюбный и радушный прием гостей" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Гости ценят дружелюбное отношение. Ваши слова, фразы и поведение несут в себе мощный посыл. Они показывают гостям, насколько вы заботитесь о них." TextWrapping="Wrap" Margin="0,0,0,15"/>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" FontSize="16">💬 Используйте в разговоре вежливые фразы:</TextBlock>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Добрый день!"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Пожалуйста"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Спасибо за понимание"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Всего хорошего!"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Быть дружелюбным нетрудно, но об этом легко забыть в суматошном ритме при наплыве гостей. Поэтому всегда помните: дружелюбие сильно влияет на гостей и их впечатления." TextWrapping="Wrap" Margin="0,10,0,15"/>
                    <Border Background="{StaticResource InfoBlue}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                        <TextBlock Text="🎯 Задача по тренировке гостеприимства: попробуйте радушно встретить 5-7 гостей. Это важный первый шаг, который поможет вам научиться свободно общаться с гостями." TextWrapping="Wrap"/>
                    </Border>
                    <TextBlock Text="А вы знали, что улыбки заразительны? Когда вы кому-то улыбаетесь, вам невольно улыбаются в ответ. Улыбайтесь каждому гостю, даже когда вы просто идете по залу." TextWrapping="Wrap" FontStyle="Italic" Margin="0,0,0,15"/>
