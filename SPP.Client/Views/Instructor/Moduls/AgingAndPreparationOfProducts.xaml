<Window x:Class="SPP.Client.Views.Instructor.Moduls.AgingAndPreparationOfProducts"
                          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Вкусно – и точка | Обучение"
WindowState="Maximized"
ResizeMode="NoResize"
Topmost="False"
Background="#F5F5F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryRed" Color="#D52B1E"/>
        <SolidColorBrush x:Key="DarkRed" Color="#A61C12"/>
        <SolidColorBrush x:Key="Gold" Color="#FFC107"/>
        <SolidColorBrush x:Key="LightGray" Color="#F9F9F9"/>
        <SolidColorBrush x:Key="MediumGray" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="TextDark" Color="#2C2C2C"/>
        <SolidColorBrush x:Key="TextMedium" Color="#5A5A5A"/>
        <SolidColorBrush x:Key="WarningYellow" Color="#FFF3E0"/>
        <SolidColorBrush x:Key="InfoBlue" Color="#F0F8FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#E8F5E9"/>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkRed}"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>

        <Style x:Key="SubTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="BulletTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="30"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,10,20,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="✕"/>
        </Style>
    </Window.Resources>

    <Grid>

        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,0">
            <StackPanel Margin="40,30,40,40">

                <!-- ================= СТРАНИЦА 1: Ваш гость (1 из 3) ================= -->
                <StackPanel x:Name="Page1">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 " FontSize="28"/>
                                <TextBlock Text="Ваш гость" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 3" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Гости – наш приоритет" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Мы делаем все, чтобы гости доверяли нам, предоставляя им отличное обслуживание и продукцию высочайшего качества." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14"/>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы работаем для гостей, ставя в приоритет качество, чистоту, гостеприимство и безопасность еды"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы работаем для того, чтобы дарить гостям моменты радости"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы слушаем и понимаем наших гостей и на основании этого постоянно улучшаемся"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Чего ожидают гости от нашей продукции? Наши гости ожидают, что продукты будут вкусные, свежие и привлекательно выглядеть. Чтобы достигать такого результата каждый день, нужно четко и последовательно соблюдать все стандарты и процедуры." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Style="{StaticResource SectionTitleStyle}">💭 Темы для размышления</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="1. Как устанавливать контакт с гостями в процессе работы?" Margin="0,5"/>
                            <TextBlock Text="2. Как сделать так, чтобы гостям у вас нравилось?" Margin="0,5"/>
                            <TextBlock Text="3. Как вы можете повлиять на впечатления гостей?" Margin="0,5"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 2: Цикл обслуживания гостей ================= -->
                <StackPanel x:Name="Page2" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 " FontSize="28"/>
                                <TextBlock Text="Ваш гость" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="2 из 3" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Цикл обслуживания гостей" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Ваш вклад в обслуживание гостей очень важен. Даже если вы не будете взаимодействовать с гостем, вы обеспечите свежесть и качество ингредиентов для продуктов." TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <TextBlock Style="{StaticResource SectionTitleStyle}">💬 Решающие моменты</TextBlock>
                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Алексей:" FontSize="14"/>
                            <TextBlock Text="«У меня много друзей в соцсетях, где они делятся свежими впечатлениями о походах в рестораны и о еде. Все должно быть на уровне, иначе об этом обязательно узнают все мои знакомые»" TextWrapping="Wrap" Margin="0,10,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionTitleStyle}">🎯 Ожидания гостей</TextBlock>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="✅ Правильно и Точно" TextAlignment="Center" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="⚡ Быстро" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                        <Border Grid.Column="4" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="😊 Дружелюбно" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <Border Background="{StaticResource WarningYellow}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="💬 Обсуждение с инструктором:"/>
                            <TextBlock Text="1. На что следует обратить внимание, чтобы соответствовать ожиданиям Алексея?" Margin="0,5,0,0"/>
                            <TextBlock Text="2. Когда вы в последний раз замечали, что кто-то изо всех сил старается вас порадовать?" Margin="0,5"/>
                            <TextBlock Text="3. Какие ошибки легко допустить, если пытаться обслуживать гостей СЛИШКОМ быстро?" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">Что необходимо делать, чтобы соответствовать ожиданиям гостей?</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Правильно и Точно:</TextBlock>
                            <TextBlock Text="• Соблюдать процедуры"/>
                            <TextBlock Text="• Не отдавать продукт, не соответствующий стандарту!"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Быстро:</TextBlock>
                            <TextBlock Text="• Сразу реагировать на информацию"/>
                            <TextBlock Text="• Заранее пополнять запасы"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Дружелюбно:</TextBlock>
                            <TextBlock Text="• Улыбаться гостям (даже если они вас не видят!)"/>
                            <TextBlock Text="• Содержать в чистоте видимые участки"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 3: Формирование впечатления гостей ================= -->
                <StackPanel x:Name="Page3" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 " FontSize="28"/>
                                <TextBlock Text="Ваш гость" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="3 из 3" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Формирование впечатления гостей" Style="{StaticResource PageTitleStyle}"/>

                    <Border Background="{StaticResource WarningYellow}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="👀 Задание для работника:"/>
                            <TextBlock Text="Пройдите в зал и понаблюдайте за работой коллег глазами гостя." Margin="0,5,0,0"/>
                            <TextBlock Text="• Что вы видите? Что слышите? Как себя чувствуете?" Margin="0,5"/>
                            <TextBlock Text="• Как работа на выдержке и пополнении запасов влияет на удовлетворение гостей?" Margin="0,5"/>
                            <TextBlock Text="• Улыбайтесь, делитесь положительными эмоциями — гости вас видят!" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource SuccessGreen}">
                        <TextBlock Text="⭐ Качество продуктов – наша главная цель! Свежие ингредиенты, правильная выдержка и пополнение запасов – залог вкусных бургеров." TextWrapping="Wrap" FontWeight="SemiBold" TextAlignment="Center"/>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее → (Безопасность)" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 4: Безопасность прежде всего ================= -->
                <StackPanel x:Name="Page4" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Обзор" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 5" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Безопасность – прежде всего" Style="{StaticResource PageTitleStyle}"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">⚠️ Техника безопасности:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Все двери в кулер/фризер и сухой сток должны быть закрыты на замок"/>
                            <TextBlock Text="• Следите, чтобы задняя дверь открывалась только в присутствии менеджера"/>
                            <TextBlock Text="• Держите все проходы и выходы свободными"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🔧 Работа с оборудованием:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Температура кулера: +1…+4°C"/>
                            <TextBlock Text="• Температура фризера: -18…-23°C"/>
                            <TextBlock Text="• Будьте осторожны при нарезке помидоров (острые лезвия!)"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🍽️ Безопасность пищи:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Используйте сеточку для волос, фартук и перчатки"/>
                            <TextBlock Text="• Храните ингредиенты в отведённых местах, соблюдайте таймеры"/>
                            <TextBlock Text="• Аккуратно вскрывайте упаковки, сразу выбрасывайте пластик"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 5: Зоны хранения и оборудование ================= -->
                <StackPanel x:Name="Page5" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Обзор" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="2 из 5" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Зоны хранения и оборудование" Style="{StaticResource PageTitleStyle}"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">📦 Булочки:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Хранятся в красных лотках"/>
                            <TextBlock Text="• Стеллажи для разморозки булочек"/>
                            <TextBlock Text="• Замороженные булочки необходимо размораживать"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🥗 Заправочный стол:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Дозаторы для соусов (кетчуп, горчица, пистолеты)"/>
                            <TextBlock Text="• Ингредиенты и ёмкости для продуктов"/>
                            <TextBlock Text="• Таймеры вторичного срока хранения"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">❄️ Холодильники и морозильники:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Холодильник под заправочным столом"/>
                            <TextBlock Text="• Пригрильный фризер (рядом с грилем)"/>
                            <TextBlock Text="• Подвесной фризер (рядом с фритюром)"/>
                            <TextBlock Text="• Сухой сток (упаковка, продукты при комн. температуре)"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🧼 Метод «трёх ванн»:</TextBlock>
                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <StackPanel>
                            <TextBlock Text="1-я ванна: мойка с моющим раствором"/>
                            <TextBlock Text="2-я ванна: ополаскивание (пустая и чистая)"/>
                            <TextBlock Text="3-я ванна: дезинфекция (не менее 5 минут)"/>
                            <TextBlock Text="• Раствор менять каждые 2 часа"/>
                            <TextBlock Text="• После дезинфекции — сушка на воздухе"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 6: Основы и термины ================= -->
                <StackPanel x:Name="Page6" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Обзор" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="3-5 из 5" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Основы и термины" Style="{StaticResource PageTitleStyle}"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">📌 Выдержка продуктов:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Перед использованием выдерживаются: сыр Чеддер и Эмменталь, помидоры, соусы в тубах."/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🔄 Принцип «Первый пришел – первый ушел» (FIFO):</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Продукты используются в порядке поступления — сначала те, у которых срок годности заканчивается раньше."/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">📊 Пополнение запасов 24/2:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Упаковки — на 24 часа"/>
                            <TextBlock Text="• Охлаждённых и замороженных продуктов — на 2 часа"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">⏲️ Сроки хранения:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Первичный — в закрытой упаковке производителя"/>
                            <TextBlock Text="• Вторичный — после вскрытия (всегда короче)"/>
                            <TextBlock Text="• НИКОГДА не используйте продукты с истекшим сроком!"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 7: Салат Айсберг и свежий лук ================= -->
