<Window x:Class="SPP.Client.Views.Instructor.Moduls.DLK"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Вкусно – и точка | Обучение"
WindowState="Maximized"
ResizeMode="NoResize"
Topmost="False"
Background="#F5F5F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryRed" Color="#D52B1E"/>
        <SolidColorBrush x:Key="DarkRed" Color="#A61C12"/>
        <SolidColorBrush x:Key="Gold" Color="#FFC107"/>
        <SolidColorBrush x:Key="LightGray" Color="#F9F9F9"/>
        <SolidColorBrush x:Key="MediumGray" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="TextDark" Color="#2C2C2C"/>
        <SolidColorBrush x:Key="TextMedium" Color="#5A5A5A"/>
        <SolidColorBrush x:Key="WarningYellow" Color="#FFF3E0"/>
        <SolidColorBrush x:Key="InfoBlue" Color="#F0F8FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#E8F5E9"/>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkRed}"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>

        <Style x:Key="SubTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="BulletTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="NumberedStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="30"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,10,20,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="✕"/>
        </Style>
    </Window.Resources>

    <Grid>

        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,0">
            <StackPanel Margin="40,30,40,40">

                <!-- ================= СТРАНИЦА 1: Ваш гость (1 из 3) ================= -->
                <StackPanel x:Name="Page1">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 " FontSize="28"/>
                                <TextBlock Text="Ваш гость" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 3" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="Гости – наш приоритет" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Мы делаем все, чтобы гости доверяли нам, предоставляя им отличное обслуживание и продукцию высочайшего качества." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14"/>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы работаем для гостей, ставя в приоритет качество, чистоту, гостеприимство и безопасность еды"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы работаем для того, чтобы дарить гостям моменты радости"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы слушаем и понимаем наших гостей и на основании этого постоянно улучшаемся"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Чего ожидают гости от нашей продукции? Наши гости ожидают очень вкусные, горячие, свежие и красивые продукты. Чтобы достигать такого результата каждый день, нужно работать с прицелом на Золотой стандарт качества продуктов и соблюдение сроков хранения." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14" FontStyle="Italic"/>

                    <TextBlock Text="Превосходить ожидания гостей должно быть нашей главной задачей каждый рабочий день в любых обстоятельствах. Даже за мелкими и на первый взгляд незначительными процедурами есть твердое обоснование: мы им следуем, чтобы соответствовать ожиданиям гостей." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Style="{StaticResource SectionTitleStyle}">💭 Темы для размышления</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="1. Как устанавливать контакт с гостями в процессе работы?" Margin="0,5"/>
                            <TextBlock Text="2. Как сделать так, чтобы гостям у вас нравилось?" Margin="0,5"/>
                            <TextBlock Text="3. Как вы можете повлиять на впечатления гостей?" Margin="0,5"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 2: Цикл обслуживания гостей ================= -->
                <StackPanel x:Name="Page2" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 " FontSize="28"/>
                                <TextBlock Text="Ваш гость" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="2 из 3" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Цикл обслуживания гостей" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Ваш вклад в обслуживание гостей очень важен. Вы поддерживаете необходимый запас продуктов и упаковки для обслуживания гостей." TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <TextBlock Style="{StaticResource SectionTitleStyle}">💬 Решающие моменты</TextBlock>
                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Ольга:" FontSize="14"/>
                            <TextBlock Text="«Я часто прихожу в это предприятие, потому что люблю бургеры с салатом и свежими овощами. Они здесь всегда такие вкусные!»" TextWrapping="Wrap" Margin="0,10,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionTitleStyle}">🎯 Ожидания гостей</TextBlock>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="✅ Правильно и Точно" TextAlignment="Center" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="⚡ Быстро" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                        <Border Grid.Column="4" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="😊 Дружелюбно" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <Border Background="{StaticResource WarningYellow}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="💬 Обсуждение с инструктором:"/>
                            <TextBlock Text="1. На что следует обратить внимание, чтобы соответствовать ожиданиям Ольги?" Margin="0,5,0,0"/>
                            <TextBlock Text="2. Когда вы в последний раз замечали, что кто-то изо всех сил старается вас порадовать?" Margin="0,5"/>
                            <TextBlock Text="3. Какие ошибки при работе в доставке можно допустить, которые потом скажутся на обслуживании?" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">Что необходимо делать, чтобы соответствовать ожиданиям гостей?</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Правильно и Точно:</TextBlock>
                            <TextBlock Text="• Соблюдать процедуры"/>
                            <TextBlock Text="• Не отдавать продукт, не соответствующий стандарту!"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Быстро:</TextBlock>
                            <TextBlock Text="• Сразу реагировать на информацию"/>
                            <TextBlock Text="• Заранее пополнять запасы"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Дружелюбно:</TextBlock>
                            <TextBlock Text="• Улыбаться гостям (даже если они вас не видят!)"/>
                            <TextBlock Text="• Содержать в чистоте видимые участки"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 3: Формирование впечатления гостей ================= -->
                <StackPanel x:Name="Page3" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 " FontSize="28"/>
                                <TextBlock Text="Ваш гость" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="3 из 3" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Формирование впечатления гостей" Style="{StaticResource PageTitleStyle}"/>

                    <Border Background="{StaticResource WarningYellow}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="👀 Задание для работника:"/>
                            <TextBlock Text="Пройдите в зал и понаблюдайте за работой коллег глазами гостя." Margin="0,5,0,0"/>
                            <TextBlock Text="• Что вы слышите? Как себя чувствуете?" Margin="0,5"/>
                            <TextBlock Text="• Насколько важны скорость и дружелюбная улыбка?" Margin="0,5"/>
                            <TextBlock Text="• Улыбайтесь, делитесь положительными эмоциями — гости вас видят!" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource SuccessGreen}">
                        <TextBlock Text="⭐ Качество продуктов и свежие ингредиенты – наша главная цель!" TextWrapping="Wrap" FontWeight="SemiBold" TextAlignment="Center"/>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее → (Безопасность)" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 4: Безопасность прежде всего ================= -->
                <StackPanel x:Name="Page4" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Обзор" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 6" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Безопасность – прежде всего" Style="{StaticResource PageTitleStyle}"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">⚠️ Предотвращение поскальзываний, спотыканий и падений:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Поддерживайте полы в чистоте"/>
                            <TextBlock Text="• Сразу вытирайте разлитое или рассыпанное"/>
                            <TextBlock Text="• Устанавливайте знак «Осторожно, мокрый пол»"/>
                            <TextBlock Text="• Носите обувь на нескользящей подошве"/>
                            <TextBlock Text="• Не загромождайте проходы коробками"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🚪 Мусорная комната (компакторная) и задняя дверь:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Дверь всегда закрыта на замок"/>
                            <TextBlock Text="• При отгрузке мусора рядом с дверью находится менеджер"/>
                            <TextBlock Text="• Не используйте дверь для входа/выхода"/>
                            <TextBlock Text="• В мусорной комнате не курить!"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 5: Работа с лестницей и перемещение грузов ================= -->
                <StackPanel x:Name="Page5" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Обзор" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="2-3 из 6" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Работа с лестницей и перемещение грузов" Style="{StaticResource PageTitleStyle}"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🪜 Правила работы с лестницей:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Проверьте исправность, чистоту и сухость ступенек"/>
                            <TextBlock Text="• Устойчиво поставьте на ровную поверхность"/>
                            <TextBlock Text="• Стойте посередине, не наклоняйтесь"/>
                            <TextBlock Text="• Не поднимайтесь на две верхние ступени"/>
                            <TextBlock Text="• Не пытайтесь дотянуться до чего-либо с лестницы"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🏋️ Правила подъёма тяжестей:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Согните ноги в коленях, спину держите прямо"/>
                            <TextBlock Text="• Держите груз как можно ближе к телу"/>
                            <TextBlock Text="• Расставьте ноги, одну немного вперёд"/>
                            <TextBlock Text="• Не поворачивайте туловище"/>
                            <TextBlock Text="• Если груз слишком тяжёлый — обратитесь за помощью"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 6: Оборудование (компактор, рокла, баллоны CO₂) ================= -->
                <StackPanel x:Name="Page6" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Обзор" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="5-6 из 6" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Оборудование для доставки" Style="{StaticResource PageTitleStyle}"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🗑️ Компактор:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Для работы в компакторной — красный халат"/>
                            <TextBlock Text="• Установка пакета: кнопка на подставке → ножная педаль → рычажный клапан → надеть пакет"/>
                            <TextBlock Text="• Прессование: поместить отходы → вернуть пресс → нажать рычажный клапан"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🛒 Рокла (гидравлическая тележка):</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Перед использованием проверить исправность"/>
                            <TextBlock Text="• Находится впереди сотрудника"/>
                            <TextBlock Text="• Запрещается: перегружать, кататься, использовать не по назначению"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🎈 Баллоны с газом CO₂:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Транспортировать на специальной тележке"/>
                            <TextBlock Text="• При погрузке/разгрузке двигатель машины выключить"/>
                            <TextBlock Text="• Баллоны должны быть с колпаками и заглушками"/>
                            <TextBlock Text="• Наполненные и пустые баллоны хранить раздельно"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 7: Сроки хранения ================= -->
                <StackPanel x:Name="Page7" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Сроки и принципы хранения" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1-2 из 9" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
