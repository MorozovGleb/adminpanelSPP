                            <TextBlock Text="• Высота от пола — не менее 15 см"/>
                            <TextBlock Text="• Расстояние от стен — не менее 5 см"/>
                            <TextBlock Text="• Расстояние от испарителя — не менее 30 см"/>
                        </StackPanel>
