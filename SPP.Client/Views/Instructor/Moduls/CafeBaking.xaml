                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">❓ Вопросы для проверки:</TextBlock>
                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <StackPanel>
                            <TextBlock Text="1. Как определить, что нужно испечь?" Margin="0,5"/>
                            <TextBlock Text="2. Какие правила техники безопасности необходимо соблюдать при работе с печью?" Margin="0,5"/>
                            <TextBlock Text="3. Какой вторичный срок хранения у булочек Панини после разморозки?" Margin="0,5"/>
                            <TextBlock Text="4. Как приготовить Чиабатту с ветчиной и сыром?" Margin="0,5"/>
                            <TextBlock Text="5. Как приготовить Круассан с ветчиной и сыром?" Margin="0,5"/>
                            <TextBlock Text="6. Как разогреть и выдать Чиабатту гостю?" Margin="0,5"/>
                            <TextBlock Text="7. Как чистить панини-гриль?" Margin="0,5"/>
                            <TextBlock Text="8. Какой Стандарт качества для печенья?" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Завершить обучение" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= ФИНАЛЬНАЯ СТРАНИЦА ================= -->
                <StackPanel x:Name="PageEnd" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="40,30" Margin="0,50,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🎉 Поздравляем!" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Вы успешно прошли обучение по выпечке" FontSize="20" Foreground="#FFEBEE" HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                            <TextBlock Text="Теперь вы готовы радовать гостей свежей выпечкой!" FontSize="18" Foreground="#FFEBEE" HorizontalAlignment="Center" Margin="0,10,0,20"/>
                            <Border Background="White" CornerRadius="30" Padding="20,10" Cursor="Hand" HorizontalAlignment="Center" MouseLeftButtonDown="RestartTraining">
                                <TextBlock Text="🔄 Пройти заново" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>