<Window x:Class="SPP.Client.Views.Instructor.Moduls.LeaderofHospitality"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Вкусно – и точка | Обучение"
  WindowState="Maximized"
  ResizeMode="NoResize"
  Topmost="False"
  Background="#F5F5F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryRed" Color="#D52B1E"/>
        <SolidColorBrush x:Key="DarkRed" Color="#A61C12"/>
        <SolidColorBrush x:Key="Gold" Color="#FFC107"/>
        <SolidColorBrush x:Key="LightGray" Color="#F9F9F9"/>
        <SolidColorBrush x:Key="MediumGray" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="TextDark" Color="#2C2C2C"/>
        <SolidColorBrush x:Key="TextMedium" Color="#5A5A5A"/>
        <SolidColorBrush x:Key="WarningYellow" Color="#FFF3E0"/>
        <SolidColorBrush x:Key="InfoBlue" Color="#F0F8FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#E8F5E9"/>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkRed}"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>

        <Style x:Key="SubTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="BulletTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="NumberedStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="30"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,10,20,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="✕"/>
        </Style>
    </Window.Resources>

    <Grid>

        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,0">
            <StackPanel Margin="40,30,40,40">

                <!-- ================= СТРАНИЦА 1: Лидер гостеприимства (обзор) ================= -->
                <StackPanel x:Name="Page1">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👑 " FontSize="28"/>
                                <TextBlock Text="Лидер гостеприимства" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="ЛИДЕР ГОСТЕПРИИМСТВА И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 2" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="Поздравляем!" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Вы – один из тех, кому посчастливилось стать Лидером гостеприимства. Это очень важная роль на предприятиях нашей компании. Благодаря Лидерам гостеприимства наши предприятия производят приятные впечатления на гостей." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Text="Вы как Лидер гостеприимства отвечаете за выполнение задач нашей компании. Этот принцип отражает наши стремления обеспечить гостям удобства, индивидуальный подход и приятное времяпрепровождение." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14"/>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource SuccessGreen}">
                        <TextBlock Text="✨ В обязанности Лидера гостеприимства входит помощь гостям и создание атмосферы дружелюбия и радушия. Вы закладываете основу для особых отношений с гостями: они всегда должны чувствовать, что им рады, они в безопасности, о них заботятся и их ценят." TextWrapping="Wrap" FontWeight="SemiBold"/>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 2: Ваша роль ================= -->
                <StackPanel x:Name="Page2" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👑 " FontSize="28"/>
                                <TextBlock Text="Ваша роль" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="ЛИДЕР ГОСТЕПРИИМСТВА И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="2 из 2" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Ваша роль" Style="{StaticResource PageTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <TextBlock Text="«Главная задача Лидера гостеприимства – ставить комфорт и впечатление гостей на первое место. Мне нравится знакомиться и общаться с людьми, поэтому для меня это идеальная работа. Но мне по-прежнему есть чему поучиться.» — Наташа" FontStyle="Italic" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Организация обслуживания гостей и неизменное стремление создать для них безопасную, комфортную обстановку и хорошее настроение – ваша главная обязанность на предприятиях нашей компании." TextWrapping="Wrap" Margin="0,15,0,15" FontSize="14"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🎯 Ожидания гостей</TextBlock>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="✅ Правильно и Точно" TextAlignment="Center" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="⚡ Быстро" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                        <Border Grid.Column="4" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="😊 Дружелюбно" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <TextBlock Style="{StaticResource SubTitleStyle}">📋 Ваши основные задачи:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Создавать отличное первое впечатление:</TextBlock>
                            <TextBlock Text="• Первым приветствовать гостей"/>
                            <TextBlock Text="• Проявлять радушие"/>
                            <TextBlock Text="• Поддерживать чистоту и атмосферу гостеприимства"/>
                            <TextBlock Text="• Хорошо знать меню и акции"/>
                            <TextBlock FontWeight="Bold" Margin="0,10,0,0">Помогать гостям:</TextBlock>
                            <TextBlock Text="• Управлять потоком гостей"/>
                            <TextBlock Text="• Помогать с Киосками и Мобильным заказом"/>
                            <TextBlock Text="• Помогать найти столик, особенно семьям с детьми"/>
                            <TextBlock FontWeight="Bold" Margin="0,10,0,0">Общаться с гостями:</TextBlock>
                            <TextBlock Text="• Фокусироваться на личном общении"/>
                            <TextBlock Text="• Отдельно приветствовать детей"/>
                            <TextBlock FontWeight="Bold" Margin="0,10,0,0">Создавать моменты хорошего настроения:</TextBlock>
                            <TextBlock Text="• Обращать внимание на «сигналы гостей»"/>
                            <TextBlock Text="• Реагировать на жалобы"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 3: Точки взаимодействия с гостями ================= -->
                <StackPanel x:Name="Page3" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Создание атмосферы гостеприимства" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="ЛИДЕРЫ ГОСТЕПРИИМСТВА" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 4" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Точки взаимодействия с гостями" Style="{StaticResource PageTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <TextBlock Text="«Гости должны унести с собой наилучшие впечатления о нашем предприятии, поэтому нам нужно сделать так, чтобы они чувствовали себя здесь легко и непринужденно. Для этого мы используем каждую возможность» — Алена" FontStyle="Italic" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Первое впечатление гостей остается с ними навсегда!" FontWeight="SemiBold" Margin="0,15,0,10" FontSize="15"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="🚪 Вход/выход"/>
                                <TextBlock Text="Отличное место, чтобы поприветствовать гостей и искренне попрощаться с ними."/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="🖥️ Киоски самообслуживания"/>
                                <TextBlock Text="Лидер может одновременно общаться и видеть разные зоны: кассы, зону выдачи и обеденный зал."/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="🛒 Прилавок"/>
                                <TextBlock Text="Можно подойти к гостям, ожидающим очереди, предложить использовать Киоск самообслуживания."/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="🍽️ Зал"/>
                                <TextBlock Text="Помощь при Обслуживании за столами, уточнить, нужно ли гостям что-то ещё."/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="📦 Выдача заказов"/>
                            <TextBlock Text="Предложить донести заказы при Обслуживании за столами, проверить готовность еды."/>
                            <TextBlock FontWeight="Bold" Margin="0,10,0,0" Text="🧸 Детский уголок"/>
                            <TextBlock Text="Зона для общения с семьями с детьми: раскраски, цветные карандаши."/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 4: Ожидания гостей (категории) ================= -->
                <StackPanel x:Name="Page4" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Создание атмосферы гостеприимства" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="ЛИДЕРЫ ГОСТЕПРИИМСТВА" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="2 из 4" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Ожидания гостей" Style="{StaticResource PageTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <TextBlock Text="«Создание дружелюбной атмосферы — это именно то, чем занимаются Лидеры гостеприимства! Ваша задача — научиться понимать гостей и соответствовать их ожиданиям» — Андрей" FontStyle="Italic" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">👨‍👩‍👧‍👦 Семьи с детьми:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Поприветствуйте детей отдельно, общайтесь с ними"/>
                            <TextBlock Text="• Предложите детский стульчик, шарики, карандаши"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">📚 Школьники:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Говорите расслабленно, но профессионально"/>
                            <TextBlock Text="• Предложите Киоски самообслуживания и мобильный заказ"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🎓 Молодежь:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Неформально, но профессионально"/>
                            <TextBlock Text="• Расскажите об акциях и новых продуктах"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">💼 Сотрудники офисов:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Будьте вежливы, используйте позитивный язык тела"/>
                            <TextBlock Text="• Помните о времени — у них короткий перерыв"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">👵 Пожилые люди:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Выучите их имена"/>
                            <TextBlock Text="• Уделите столько времени, сколько потребуется"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">⭐ Постоянные гости:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Называйте по имени"/>
                            <TextBlock Text="• Готовьте еду заранее, если возможно"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">♿ Люди с ограниченными возможностями здоровья:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Обращайтесь напрямую, а не к сопровождающему"/>
                            <TextBlock Text="• Представьтесь, предложите помощь"/>
                            <TextBlock Text="• Не относитесь снисходительно или с жалостью"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 5: Приветствие и прощание ================= -->
                <StackPanel x:Name="Page5" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Создание атмосферы гостеприимства" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="ЛИДЕРЫ ГОСТЕПРИИМСТВА" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="3 из 4" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Приветствие и прощание" Style="{StaticResource PageTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource WarningYellow}">
                        <TextBlock Text="👋 Теперь ваша очередь! Попробуйте поздороваться и попрощаться с гостями." TextWrapping="Wrap" FontSize="15"/>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">📋 Основные действия:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Первым приветствовать гостей, когда они заходят"/>
                            <TextBlock Text="• Проявлять радушие"/>
                            <TextBlock Text="• Встречать семью с улыбкой, отдельно приветствовать детей"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 6: Создание положительного первого впечатления ================= -->
                <StackPanel x:Name="Page6" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Улучшение опыта посещения" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="ЛИДЕРЫ ГОСТЕПРИИМСТВА" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 10" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Создание положительного первого впечатления" Style="{StaticResource PageTitleStyle}"/>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <TextBlock Text="«Люди любят, когда их приветствуют, выражают им признательность, обращаются к ним — это вызывает чувство доверия.» — Алена" FontStyle="Italic" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">💬 Приветствие гостей:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Открывайте/придерживайте входные двери"/>
                            <TextBlock Text="• Посмотрите в глаза, поприветствуйте искренне, тепло"/>
                            <TextBlock Text="• Разнообразьте приветствие: «Здравствуйте!», «Доброе утро!», «Рады Вас видеть!»"/>
