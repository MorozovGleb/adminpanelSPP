<Window x:Class="SPP.Client.Views.Manager.CreateSchedule"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Составление расписания — Вкусно и точка"
        Height="600"
        Width="850"
        Background="#F7F9F8"
        WindowStartupLocation="CenterScreen">


    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">
            <TextBox x:Name="ChatOutput" TextWrapping="Wrap" FontSize="14"/>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Сгенерировать расписание" Width="200" Height="35" Click="Generate_Click"/>
        </StackPanel>
    </Grid>
</Window>