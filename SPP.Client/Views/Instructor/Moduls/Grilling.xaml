<Window x:Class="SPP.Client.Views.Instructor.Moduls.Grilling"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Вкусно – и точка | Обучение"
WindowState="Maximized"
ResizeMode="NoResize"
Topmost="False"
Background="#F5F5F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryRed" Color="#D52B1E"/>
        <SolidColorBrush x:Key="DarkRed" Color="#A61C12"/>
        <SolidColorBrush x:Key="Gold" Color="#FFC107"/>
        <SolidColorBrush x:Key="LightGray" Color="#F9F9F9"/>
        <SolidColorBrush x:Key="MediumGray" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="TextDark" Color="#2C2C2C"/>
        <SolidColorBrush x:Key="TextMedium" Color="#5A5A5A"/>
        <SolidColorBrush x:Key="WarningYellow" Color="#FFF3E0"/>
        <SolidColorBrush x:Key="InfoBlue" Color="#F0F8FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#E8F5E9"/>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DarkRed}"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>

        <Style x:Key="SubTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="BulletTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="30"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,10,20,0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="✕"/>
        </Style>
    </Window.Resources>

    <Grid>

        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,0">
            <StackPanel Margin="40,30,40,40">

                <!-- ================= СТРАНИЦА 1: Ваш гость (1 из 3) ================= -->
                <StackPanel x:Name="Page1">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🍔 " FontSize="28"/>
                                <TextBlock Text="Ваш гость" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 3" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Гости – наш приоритет" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Мы делаем все, чтобы гости доверяли нам, предоставляя им отличное обслуживание и продукцию высочайшего качества." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14"/>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы работаем для гостей, ставя в приоритет качество, чистоту, гостеприимство и безопасность еды"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы работаем для того, чтобы дарить гостям моменты радости"/>
                            <TextBlock Style="{StaticResource BulletTextStyle}" Text="✓ Мы слушаем и понимаем наших гостей и на основании этого постоянно улучшаемся"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Чего ожидает гость, заказывая продукты на гриле? Гостям нравится вкус свежеприготовленного мяса; каждый кусочек нежной и сочной котлеты дарит море удовольствия." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14" FontStyle="Italic"/>

                    <TextBlock Text="Просто помните: хоть вы и не взаимодействуете с гостями напрямую и можете даже не видеть их, отличные продукты, приготовленные на гриле, оказывают большое влияние на впечатления гостей. Наши сандвичи зачастую становятся главным элементом заказа. Вряд ли кому-то понравится пересушенный или холодный продукт. А ведь кто-то прямо сейчас мечтает о сочном бургере, котлеты для которого будете готовить вы. Люди устают за день и мечтают отдохнуть и насладиться вкусной едой. Дайте им эту возможность." TextWrapping="Wrap" Margin="0,0,0,15" FontSize="14"/>

                    <TextBlock Style="{StaticResource SectionTitleStyle}">💭 Темы для размышления</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="1. Как устанавливать контакт с гостями в процессе работы?" Margin="0,5"/>
                            <TextBlock Text="2. Как обеспечить гостю хорошее впечатление от посещения предприятия?" Margin="0,5"/>
                            <TextBlock Text="3. Как вы можете повлиять на впечатления гостей?" Margin="0,5"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 2: Цикл обслуживания гостей ================= -->
                <StackPanel x:Name="Page2" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🍔 " FontSize="28"/>
                                <TextBlock Text="Ваш гость" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="2 из 3" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Цикл обслуживания гостей" Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock Text="Ваш вклад в обслуживание гостей очень важен. Даже если вы не будете взаимодействовать с гостем, вы приготовите для него нежные, сочные, обжаренные и приправленные мясные котлеты на гриле." TextWrapping="Wrap" Margin="0,0,0,15"/>

                    <TextBlock Style="{StaticResource SectionTitleStyle}">💬 Решающие моменты</TextBlock>
                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource InfoBlue}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Сергей:" FontSize="14"/>
                            <TextBlock Text="«Все очень просто. Мне нравятся эти бургеры!»" TextWrapping="Wrap" Margin="0,10,0,0" FontStyle="Italic" FontSize="16"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SectionTitleStyle}">🎯 Ожидания гостей</TextBlock>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="✅ Правильно и Точно" TextAlignment="Center" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="⚡ Быстро" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                        <Border Grid.Column="4" Background="{StaticResource MediumGray}" CornerRadius="10" Padding="10">
                            <TextBlock Text="😊 Дружелюбно" TextAlignment="Center" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <Border Background="{StaticResource WarningYellow}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="💬 Обсуждение с инструктором:"/>
                            <TextBlock Text="1. На какие детали следует обратить внимание, чтобы соответствовать ожиданиям Сергея?" Margin="0,5,0,0"/>
                            <TextBlock Text="2. Когда вы в последний раз ощущали, что кто-то прилагает чуть больше усилий, чтобы вам было хорошо?" Margin="0,5"/>
                            <TextBlock Text="3. Какие ошибки вы можете совершить, если сделаете заказ СЛИШКОМ быстро?" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">Что необходимо делать, чтобы соответствовать ожиданиям гостей?</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Правильно и Точно:</TextBlock>
                            <TextBlock Text="• Соблюдать процедуры"/>
                            <TextBlock Text="• Не отдавать продукт, не соответствующий стандарту!"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Быстро:</TextBlock>
                            <TextBlock Text="• Сразу реагировать на информацию на мониторах"/>
                            <TextBlock Text="• Координировать действия с коллегами"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Дружелюбно:</TextBlock>
                            <TextBlock Text="• Улыбаться гостям (даже если они вас не видят!)"/>
                            <TextBlock Text="• Содержать в чистоте видимые участки"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 3: Формирование впечатления + Золотой Стандарт ================= -->
                <StackPanel x:Name="Page3" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🍔 " FontSize="28"/>
                                <TextBlock Text="Ваш гость" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ И ИНСТРУКТОР" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="3 из 3" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Формирование впечатления гостей" Style="{StaticResource PageTitleStyle}"/>

                    <Border Background="{StaticResource WarningYellow}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="👀 Задание для работника:"/>
                            <TextBlock Text="Пройдите в зал и понаблюдайте за работой с гостями глазами гостя." Margin="0,5,0,0"/>
                            <TextBlock Text="• Что вы слышите? Как вы себя чувствуете?" Margin="0,5"/>
                            <TextBlock Text="• Насколько важна чистота в зоне производства?" Margin="0,5"/>
                            <TextBlock Text="• Улыбайтесь, кивайте, делитесь положительными эмоциями — гости вас видят!" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource SuccessGreen}">
                        <TextBlock Text="⭐ Золотой Стандарт Качества – это описание характеристик качества, которым должны соответствовать продукты. Продукты должны аккуратно и аппетитно выглядеть, иметь правильную температуру и текстуру, быть вкусными. Никогда не отдавайте продукт гостю, если он не соответствует стандарту!" TextWrapping="Wrap" FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🥩 Золотой Стандарт Качества котлет из говядины:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold">Внешний вид:</TextBlock>
                            <TextBlock Text="Равномерно обжарена, сочная, аппетитная, без видимых дефектов." Margin="0,0,0,10"/>
                            <TextBlock FontWeight="Bold">Температура и текстура:</TextBlock>
                            <TextBlock Text="Горячая, нежная, сочная, хорошо прожаренная." Margin="0,0,0,10"/>
                            <TextBlock FontWeight="Bold">Вкус:</TextBlock>
                            <TextBlock Text="Натуральный вкус сочной говядины с добавлением приправ и лука (для 10:1)."/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее → (Безопасность)" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 4: Безопасность прежде всего ================= -->
                <StackPanel x:Name="Page4" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Обзор" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 5" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Безопасность – прежде всего" Style="{StaticResource PageTitleStyle}"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">⚠️ Безопасность на рабочем месте:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Предупреждайте коллег, куда вы идёте"/>
                            <TextBlock Text="• Проверяйте оборудование на предмет рисков, сразу вытирайте пролитое"/>
                            <TextBlock Text="• Аккуратно обращайтесь с горячими поверхностями гриля"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🍽️ Безопасность пищи:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Мойте руки перед началом, после работы, при работе с сырыми продуктами, не реже раза в час"/>
                            <TextBlock Text="• Используйте голубые одноразовые перчатки для гриля"/>
                            <TextBlock Text="• Используйте щипцы при снятии мяса с гриля"/>
                            <TextBlock Text="• Проверяйте сроки годности на упаковках"/>
                            <TextBlock Text="• Выбрасывайте продукты с истекшим сроком в красный контейнер"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource SuccessGreen}">
                        <TextBlock Text="✅ Мы предоставляем нашим гостям только доготовленный и безопасный продукт! Если полуфабрикаты разморожены или не доготовлены — немедленно сообщите менеджеру." TextWrapping="Wrap" FontWeight="SemiBold"/>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 5: Оборудование (грили, UHC) ================= -->
                <StackPanel x:Name="Page5" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Обзор" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="2-3 из 5" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Грили и UHC" Style="{StaticResource PageTitleStyle}"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🔥 Контактные грили:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Открываются и закрываются автоматически, жарят с двух сторон"/>
                            <TextBlock Text="• Жарочная поверхность — створка (узкие или широкие)"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">🔧 Мелкое оборудование для гриля:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Лопатка и металлические щипцы"/>
                            <TextBlock Text="• Дозатор для приправ (зелёный — для 10:1, серый — для 3:1/4:1)"/>
                            <TextBlock Text="• Шейкер для лука (только для 10:1)"/>
                            <TextBlock Text="• Скребок для гриля и линейка с резиновой насадкой"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Style="{StaticResource SubTitleStyle}">📊 Мониторы и UHC:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Монитор «Смотри и готовь» — показывает, сколько котлет приготовить"/>
                            <TextBlock Text="• Монитор eProduction — базовый уровень продуктов в UHC"/>
                            <TextBlock Text="• UHC — шкаф с подогревом для хранения готовых котлет"/>
                            <TextBlock Text="• Лотки UHC: янтарный (10:1), белый (4:1), серый (3:1)"/>
                            <TextBlock Text="• Красный контейнер — для пищевых отходов"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource PrimaryRed}" MouseLeftButtonDown="NextPage">
                        <TextBlock Text="Далее →" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Style="{StaticResource NavButtonStyle}" Background="{StaticResource MediumGray}" MouseLeftButtonDown="PrevPage">
                        <TextBlock Text="← Назад" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                    </Border>
                </StackPanel>

                <!-- ================= СТРАНИЦА 6: Принципы приготовления ================= -->
                <StackPanel x:Name="Page6" Visibility="Collapsed">
                    <Border Background="{StaticResource PrimaryRed}" CornerRadius="10" Padding="20,15" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Говядина" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="РАБОТНИКИ" FontSize="14" Foreground="#FFEBEE" Margin="0,0,15,0"/>
                                <Border Background="#FFEBEE" CornerRadius="20" Padding="12,5">
                                    <TextBlock Text="1 из 7" FontWeight="Bold" Foreground="{StaticResource PrimaryRed}"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Принципы приготовления на гриле" Style="{StaticResource PageTitleStyle}"/>

                    <TextBlock Style="{StaticResource SubTitleStyle}">📊 Базовый уровень и монитор «Смотри и готовь»:</TextBlock>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="• Монитор eProduction определяет, сколько котлет должно быть в UHC"/>
                            <TextBlock Text="• Монитор «Смотри и готовь» показывает, сколько нужно приготовить"/>
                            <TextBlock Text="• Принцип «Смотри, Сбрасывай, Готовь»"/>
                            <TextBlock Text="• Максимальная партия: 10:1 — 6 шт, 4:1 — 4 шт, 3:1 — 4 шт"/>
                        </StackPanel>
                    </Border>

