                            <TextBlock Text="Вы успешно прошли обучение по роли Лидера гостеприимства" FontSize="20" Foreground="#FFEBEE" HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
