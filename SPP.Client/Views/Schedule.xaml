<Window x:Class="SPP.Client.Views.Schedule"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Мое расписание"
 Height="600"
 Width="800"
 WindowStartupLocation="CenterScreen"
 Background="#F7F9F8"
 ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Моё расписание" FontSize="20" FontWeight="Bold" 
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button x:Name="RefreshButton" Content="🔄 Обновить" 
                    Click="RefreshButton_Click" Width="120" Height="30" Margin="0,0,10,0"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="UserNameText" Text="" 
                       VerticalAlignment="Center" FontSize="14" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Вывод расписания -->
        <RichTextBox x:Name="OutputBox" Grid.Row="1" 
                     IsReadOnly="True" 
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"
                     Background="#1E1E1E"
                     Foreground="#DCDCDC"
                     BorderBrush="#333333">
            <FlowDocument>
                <Paragraph>
                    <Run Text="Загрузка расписания..."/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
    </Grid>
</Window>